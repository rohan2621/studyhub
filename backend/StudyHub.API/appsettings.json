{
  "ConnectionStrings": {
    "DefaultConnection": "Host=your-supabase-db-host;Database=postgres;Username=postgres;Password=your-password;Port=5432;SSL Mode=Require;Trust Server Certificate=true",
    "Redis": "rediss://default:your-redis-password@your-upstash-host:6379"
  },
  "Jwt": {
    "Secret": "your-super-secret-jwt-key-minimum-32-chars-long",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "Issuer": "StudyHub",
    "Audience": "StudyHubUsers"
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "FromEmail": "your-email@gmail.com",
    "FromName": "StudyHub"
  },
  "Supabase": {
    "Url": "https://your-supabase-url.supabase.co",
    "ServiceRoleKey": "your-supabase-service-role-key",
    "BucketName": "studyhub-files"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost"
}