{
  "expo": {
    "name": "StudyHub",
    "slug": "studyhub",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "studyhub",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.studyhub.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5f1430f1-02bd-40b8-baa9-0c15692c5f52"
      }
    },
    "owner": "studysub"
  }
}
